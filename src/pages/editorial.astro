---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Ekreacja — Editorial</title>

  <script is:inline>
    (function() {
      var p = window.location.pathname;
      if (p === '/login' || p === '/login/') return;
      try { if (localStorage.getItem('ekreacja_auth') === 'ok') return; } catch (e) {}
      document.documentElement.style.visibility = 'hidden';
      window.location.replace('/login');
    })();
  </script>

  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <script is:inline src="https://unpkg.com/lucide@latest"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Newsreader:ital,wght@0,300..700;1,300..700&display=swap" rel="stylesheet" />

  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Fraunces', 'serif'],
            body: ['Newsreader', 'serif'],
          },
          colors: {
            paper: '#F5F1E8',
            paperdark: '#EDE7D8',
            ink: '#1A1614',
            inkmute: '#5C534A',
            terra: '#D97757',
            terradark: '#B85C3F',
          },
        },
      },
    };
  </script>

  <style>
    html { scroll-behavior: smooth; background: #F5F1E8; }
    body {
      font-family: 'Newsreader', serif;
      font-weight: 350;
      color: #1A1614;
      background: #F5F1E8;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    ::selection { background: #D97757; color: white; }

    .display { font-family: 'Fraunces', serif; }
    .num { font-family: 'Fraunces', serif; font-feature-settings: 'tnum'; }

    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.in { opacity: 1; transform: translateY(0); }

    .stagger > * { opacity: 0; transform: translateY(20px); animation: rise 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .stagger > *:nth-child(1) { animation-delay: 0.1s; }
    .stagger > *:nth-child(2) { animation-delay: 0.3s; }
    .stagger > *:nth-child(3) { animation-delay: 0.55s; }
    .stagger > *:nth-child(4) { animation-delay: 0.8s; }
    @keyframes rise { to { opacity: 1; transform: translateY(0); } }

    .rule { border-top: 1px solid #1A1614; opacity: 0.15; }
    .rule-dot { border-top: 1px dotted #1A1614; opacity: 0.25; }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.06;
      mix-blend-mode: multiply;
      z-index: 100;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    .underline-fancy {
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 4px;
      text-decoration-color: rgba(26, 22, 20, 0.3);
      transition: text-decoration-color 0.3s;
    }
    .underline-fancy:hover { text-decoration-color: #D97757; }

    .smallcaps {
      font-family: 'Fraunces', serif;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-size: 11px;
      color: #5C534A;
    }

    .service-row {
      transition: background 0.4s ease, padding-left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .service-row:hover {
      background: rgba(217, 119, 87, 0.06);
      padding-left: 24px;
    }
    .service-row:hover .arrow { transform: translateX(8px); color: #D97757; }
    .arrow { transition: transform 0.4s, color 0.4s; }

    .back-link {
      position: fixed;
      top: 24px;
      left: 24px;
      z-index: 60;
      font-family: 'Fraunces', serif;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #5C534A;
      background: rgba(245, 241, 232, 0.85);
      backdrop-filter: blur(8px);
      padding: 8px 14px;
      border: 1px solid rgba(26, 22, 20, 0.12);
      border-radius: 999px;
      transition: all 0.3s;
    }
    .back-link:hover { color: #1A1614; border-color: rgba(26, 22, 20, 0.3); }
  </style>
</head>

<body class="font-body">

  <a href="/" class="back-link">← Wszystkie style</a>

  <header class="border-b border-ink/15">
    <div class="max-w-5xl mx-auto px-6 md:px-10 py-5 flex items-center justify-between">
      <div class="smallcaps">Vol. 18 · 2007–2026</div>
      <div class="display text-xl md:text-2xl tracking-tight">Ekreacja</div>
      <div class="smallcaps hidden md:block">Jelcz-Laskowice</div>
    </div>
    <div class="max-w-5xl mx-auto px-6 md:px-10 pb-4 flex items-center justify-center gap-8 text-sm">
      <a href="#onas" class="underline-fancy">O nas</a>
      <span class="text-ink/30">·</span>
      <a href="#oferta" class="underline-fancy">Co robimy</a>
      <span class="text-ink/30">·</span>
      <a href="#kontakt" class="underline-fancy">Kontakt</a>
    </div>
  </header>

  <section class="relative py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6 md:px-10 stagger">

      <div class="smallcaps mb-10">Agencja kreatywna — od osiemnastu lat</div>

      <h1 class="display font-light text-[12vw] md:text-[9vw] lg:text-[8.5rem] leading-[0.92] tracking-[-0.03em]">
        Tworzymy <span class="italic font-normal text-terra">widoczność,</span><br />
        która zamienia się<br />
        w&nbsp;Twój&nbsp;zysk.
      </h1>

      <div class="mt-16 grid md:grid-cols-12 gap-8 items-end">
        <p class="md:col-span-7 text-xl md:text-2xl leading-relaxed text-ink/80 font-light">
          Strony WWW, sklepy on-line, SEO, Google Ads, social media, video — wszystko czego potrzebujesz, żeby zaistnieć w internecie. Pod jednym dachem, od jednej agencji.
        </p>
        <div class="md:col-span-5 md:text-right">
          <a href="#oferta" class="display italic text-xl underline-fancy">
            Czytaj dalej ↓
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="rule max-w-5xl mx-auto"></div>

  <section id="onas" class="py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6 md:px-10">

      <div class="grid md:grid-cols-12 gap-10 reveal">
        <div class="md:col-span-3">
          <div class="smallcaps mb-4">Rozdział 01</div>
          <div class="display num text-7xl md:text-8xl font-light leading-none text-terra">01</div>
        </div>

        <div class="md:col-span-9">
          <h2 class="display font-light text-4xl md:text-5xl leading-tight mb-10">
            Kim <span class="italic">jesteśmy</span>?
          </h2>

          <div class="space-y-7 text-lg md:text-xl leading-relaxed text-ink/85 font-light max-w-2xl">
            <p class="display italic text-2xl md:text-3xl font-light text-terradark">
              „Działamy w branży od ponad 18 lat."
            </p>
            <p>
              Nasz zespół tworzą zdolni programiści, graficy, copywriterzy, specjaliści od social media, fotografii, video oraz marketingu on-line.
            </p>
            <p>
              Wybierając naszą agencję wybierasz obsługę na najwyższym poziomie, terminowość i pewność, że nie jesteś jednym z tysiąca klientów jak w innej firmie.
            </p>
            <p>
              Nasz cel to stworzenie optymalnej widoczności w świecie on-line. Chcemy tę widoczność zamienić w Twój zysk — dzięki kreatywności, wiedzy, doświadczeniu i zaangażowaniu.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="rule-dot max-w-5xl mx-auto"></div>

  <section id="oferta" class="py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6 md:px-10">

      <div class="grid md:grid-cols-12 gap-10 mb-16 reveal">
        <div class="md:col-span-3">
          <div class="smallcaps mb-4">Rozdział 02</div>
          <div class="display num text-7xl md:text-8xl font-light leading-none text-terra">02</div>
        </div>
        <div class="md:col-span-9">
          <h2 class="display font-light text-4xl md:text-5xl leading-tight">
            Co dla Ciebie <span class="italic">zrobimy</span>?
          </h2>
        </div>
      </div>

      <div class="border-t border-ink/15 reveal">

        <a href="#kontakt" class="service-row block py-7 border-b border-ink/15 grid md:grid-cols-12 gap-6 items-baseline">
          <div class="md:col-span-1 num text-sm text-inkmute">01</div>
          <div class="md:col-span-3 display text-2xl md:text-3xl font-light">Strony WWW</div>
          <div class="md:col-span-7 text-ink/70">Nowoczesne strony zgodne z wytycznymi Google. Responsywne, szyte pod Twoich klientów. Także modernizacja istniejących.</div>
          <div class="md:col-span-1 text-right arrow text-inkmute">→</div>
        </a>

        <a href="#kontakt" class="service-row block py-7 border-b border-ink/15 grid md:grid-cols-12 gap-6 items-baseline">
          <div class="md:col-span-1 num text-sm text-inkmute">02</div>
          <div class="md:col-span-3 display text-2xl md:text-3xl font-light">Sklepy on-line</div>
          <div class="md:col-span-7 text-ink/70">Budujemy e-sklepy idealnie dopasowane pod Twojego klienta. Dedykowane rozwiązania — nic z półki.</div>
          <div class="md:col-span-1 text-right arrow text-inkmute">→</div>
        </a>

        <a href="#kontakt" class="service-row block py-7 border-b border-ink/15 grid md:grid-cols-12 gap-6 items-baseline">
          <div class="md:col-span-1 num text-sm text-inkmute">03</div>
          <div class="md:col-span-3 display text-2xl md:text-3xl font-light">SEO &amp; Google Ads</div>
          <div class="md:col-span-7 text-ink/70">Wysokie pozycje w wyszukiwarce. Pozycjonowanie długofalowe i szybkie reklamy sponsorowane.</div>
          <div class="md:col-span-1 text-right arrow text-inkmute">→</div>
        </a>

        <a href="#kontakt" class="service-row block py-7 border-b border-ink/15 grid md:grid-cols-12 gap-6 items-baseline">
          <div class="md:col-span-1 num text-sm text-inkmute">04</div>
          <div class="md:col-span-3 display text-2xl md:text-3xl font-light">Social media</div>
          <div class="md:col-span-7 text-ink/70">Prowadzenie profilu Facebook. Posty produktowe, branżowe, wizerunkowe. Naturalne zaangażowanie.</div>
          <div class="md:col-span-1 text-right arrow text-inkmute">→</div>
        </a>

        <a href="#kontakt" class="service-row block py-7 border-b border-ink/15 grid md:grid-cols-12 gap-6 items-baseline">
          <div class="md:col-span-1 num text-sm text-inkmute">05</div>
          <div class="md:col-span-3 display text-2xl md:text-3xl font-light">Content marketing</div>
          <div class="md:col-span-7 text-ink/70">Wartościowe, unikalne treści. Marketing szeptany jako Twój osobisty dział PR w sieci.</div>
          <div class="md:col-span-1 text-right arrow text-inkmute">→</div>
        </a>

        <a href="#kontakt" class="service-row block py-7 border-b border-ink/15 grid md:grid-cols-12 gap-6 items-baseline">
          <div class="md:col-span-1 num text-sm text-inkmute">06</div>
          <div class="md:col-span-3 display text-2xl md:text-3xl font-light">Video &amp; foto</div>
          <div class="md:col-span-7 text-ink/70">Sesje zdjęciowe, ujęcia z drona, prezentacje video, YouTube. Pokażemy Twoją firmę z każdej strony.</div>
          <div class="md:col-span-1 text-right arrow text-inkmute">→</div>
        </a>

      </div>
    </div>
  </section>

  <div class="rule-dot max-w-5xl mx-auto"></div>

  <section id="kontakt" class="py-24 md:py-36 bg-paperdark/40">
    <div class="max-w-5xl mx-auto px-6 md:px-10">

      <div class="grid md:grid-cols-12 gap-10 reveal">
        <div class="md:col-span-3">
          <div class="smallcaps mb-4">Rozdział 03</div>
          <div class="display num text-7xl md:text-8xl font-light leading-none text-terra">03</div>
        </div>

        <div class="md:col-span-9">
          <h2 class="display font-light text-5xl md:text-7xl leading-[0.95] mb-12">
            Zadzwoń <span class="italic">teraz.</span>
          </h2>

          <p class="text-xl text-ink/75 mb-14 max-w-lg font-light leading-relaxed">
            Tworzymy z pasją. Powiedz nam o swoim projekcie — odezwiemy się tego samego dnia.
          </p>

          <div class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-8 border-b border-ink/15 pb-5">
              <div class="smallcaps md:w-28">Telefon</div>
              <a href="tel:+48509289649" class="display text-2xl md:text-3xl font-light underline-fancy">509 289 649</a>
            </div>
            <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-8 border-b border-ink/15 pb-5">
              <div class="smallcaps md:w-28">Email</div>
              <a href="mailto:dorota@e-kreacja.com.pl" class="display text-xl md:text-2xl font-light underline-fancy">dorota@e-kreacja.com.pl</a>
            </div>
            <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-8 border-b border-ink/15 pb-5">
              <div class="smallcaps md:w-28">Adres</div>
              <div class="display text-xl md:text-2xl font-light">Jelcz-Laskowice, ul. Oławska 70/14</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="border-t border-ink/15">
    <div class="max-w-5xl mx-auto px-6 md:px-10 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-inkmute">
      <div class="display italic">Ekreacja — Agencja kreatywna od 2007</div>
      <div class="flex items-center gap-5">
        <a href="https://www.facebook.com/Ekreacja/" target="_blank" rel="noopener" class="underline-fancy">Facebook</a>
        <span class="smallcaps">© MMXXVI</span>
      </div>
    </div>
  </footer>

  <script is:inline>
    lucide.createIcons();
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</body>
</html>
