          <h2 class="hero-title text-4xl md:text-6xl">
            co_robimy?
          </h2>
        </div>
      </div>

      <div class="border-t border-b border-ink reveal">
        <a href="#kontakt" class="service-row block py-5 px-4 border-b border-ink grid md:grid-cols-12 gap-4 items-center cursor-pointer">
          <div class="md:col-span-1 text-xs marker">[01]</div>
          <div class="md:col-span-3 font-bold uppercase tracking-tight">Strony WWW</div>
