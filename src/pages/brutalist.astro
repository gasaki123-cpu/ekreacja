<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Ekreacja — Brutalist</title>

  <script is:inline>
    (function() {
      var p = window.location.pathname;
      if (p === '/login' || p === '/login/') return;
      try { if (localStorage.getItem('ekreacja_auth') === 'ok') return; } catch (e) {}
      document.documentElement.style.visibility = 'hidden';
      window.location.replace('/login');
    })();
  </script>

  <script is:inline src="https://cdn.tailwindcss.com"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />

  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { mono: ['JetBrains Mono', 'monospace'] },
          colors: { off: '#FAFAF7', ink: '#0A0A0A', acid: '#D4FF00' },
        },
      },
    };
  </script>

  <style>
    html { scroll-behavior: smooth; background: #FAFAF7; }
    body {
      font-family: 'JetBrains Mono', monospace;
      color: #0A0A0A;
      background: #FAFAF7;
      overflow-x: hidden;
      font-size: 14px;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
    }
    ::selection { background: #0A0A0A; color: #D4FF00; }

    .reveal { opacity: 0; transition: opacity 0.6s; }
    .reveal.in { opacity: 1; }

    .blink::after {
      content: '_';
      animation: blink 1.05s steps(2, start) infinite;
      margin-left: 2px;
    }
    @keyframes blink { to { visibility: hidden; } }

    .service-row {
      transition: background 0.15s, color 0.15s;
    }
    .service-row:hover {
      background: #0A0A0A;
      color: #D4FF00;
    }
    .service-row:hover .marker { color: #D4FF00; }

    .marquee {
      display: flex;
      animation: scroll 30s linear infinite;
      white-space: nowrap;
    }
    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .back-link {
      position: fixed;
      top: 16px;
      left: 16px;
      z-index: 60;
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: #0A0A0A;
      color: #FAFAF7;
      padding: 8px 14px;
      transition: background 0.15s;
    }
    .back-link:hover { background: #D4FF00; color: #0A0A0A; }

    .underline-thick { text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 4px; }

    .hero-title {
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 0.92;
    }
  </style>
</head>

<body>

  <a href="/" class="back-link">[← all styles]</a>

  <nav class="border-b border-ink">
    <div class="max-w-6xl mx-auto px-6 md:px-8 h-14 flex items-center justify-between">
      <a href="#top" class="font-bold tracking-tight">EKREACJA.</a>
      <div class="flex items-center gap-6 text-xs uppercase tracking-wider">
        <a href="#onas" class="hover:underline underline-thick">[01] o-nas</a>
        <a href="#oferta" class="hover:underline underline-thick">[02] co-robimy</a>
        <a href="#kontakt" class="hover:underline underline-thick">[03] kontakt</a>
      </div>
    </div>
  </nav>

  <section id="top" class="border-b border-ink">
    <div class="max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24">

      <div class="text-xs uppercase tracking-wider text-ink/60 mb-12 flex items-center gap-3">
        <span class="inline-block w-2 h-2 bg-ink"></span>
        <span>system.ekreacja.v18 // agencja kreatywna // 2007–<span id="year">2026</span></span>
      </div>

      <h1 class="hero-title text-[12vw] md:text-[8vw] lg:text-[6.5rem] mb-12">
        AGENCJA<br />
        KREATYWNA.<span class="blink"></span>
      </h1>

      <div class="grid md:grid-cols-12 gap-6 border-t border-ink pt-10">
        <div class="md:col-span-2 text-xs uppercase tracking-wider text-ink/60">
          <div>// description</div>
        </div>
        <div class="md:col-span-7 text-base md:text-lg leading-relaxed">
          Od osiemnastu lat budujemy widoczność, która zamienia się w Twój zysk.
          Strony, sklepy, SEO, reklamy, social, video. Wszystko pod jednym dachem.
        </div>
        <div class="md:col-span-3 md:text-right">
          <a href="#oferta" class="inline-block bg-ink text-off px-5 py-3 text-xs uppercase tracking-wider hover:bg-acid hover:text-ink transition">
            [↓] zobacz co robimy
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-ink overflow-hidden bg-ink text-off">
      <div class="marquee py-3 text-sm uppercase tracking-widest">
        <span class="px-6">★ strony www</span><span class="px-6">★ sklepy on-line</span><span class="px-6">★ seo &amp; google ads</span><span class="px-6">★ social media</span><span class="px-6">★ content marketing</span><span class="px-6">★ video &amp; foto</span>
        <span class="px-6">★ strony www</span><span class="px-6">★ sklepy on-line</span><span class="px-6">★ seo &amp; google ads</span><span class="px-6">★ social media</span><span class="px-6">★ content marketing</span><span class="px-6">★ video &amp; foto</span>
      </div>
    </div>
  </section>

  <section id="onas" class="border-b border-ink">
    <div class="max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24">

      <div class="grid md:grid-cols-12 gap-8 mb-12">
        <div class="md:col-span-2 text-xs uppercase tracking-wider text-ink/60">
          <div>/section_01</div>
        </div>
        <div class="md:col-span-10">
          <h2 class="hero-title text-4xl md:text-6xl mb-2">
            kim_jestesmy?
          </h2>
        </div>
      </div>

      <div class="grid md:grid-cols-12 gap-8 reveal">
        <div class="md:col-span-2 text-xs uppercase tracking-wider text-ink/60">
          <div>// content</div>
        </div>
        <div class="md:col-span-10 space-y-5 text-base md:text-lg max-w-3xl">
          <p>
            <span class="bg-acid px-1">Działamy w branży od ponad 18 lat.</span> Nasz zespół tworzą zdolni programiści, graficy, copywriterzy, specjaliści od social media, fotografii, video oraz marketingu on-line.
          </p>
          <p>
            Wybierając naszą agencję wybierasz obsługę na najwyższym poziomie, terminowość i pewność, że nie jesteś jednym z tysiąca klientów jak w innej firmie.
          </p>
