  <footer>
    <div class="max-w-6xl mx-auto px-6 md:px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs uppercase tracking-wider text-ink/60">
      <div>// ekreacja_v18 — agencja kreatywna od 2007</div>
      <div>© MMXXVI — wszystkie prawa zastrzeżone</div>
    </div>
  </footer>

  <script is:inline>
    document.getElementById('year').textContent = new Date().getFullYear();
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</body>
</html>
