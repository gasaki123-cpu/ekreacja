---
import { AUTH_HASH } from '../config/auth.ts';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Ekreacja — dostęp</title>

  <script is:inline src="https://cdn.tailwindcss.com"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

  <style>
    html { background: #07070A; }
    body {
      font-family: 'Geist', system-ui, sans-serif;
      color: #EDEDF2;
      background: #07070A;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 24px;
      overflow: hidden;
      -webkit-font-smoothing: antialiased;
      letter-spacing: -0.01em;
    }
    ::selection { background: rgba(149, 57, 254, 0.35); color: white; }

    .serif { font-family: 'Instrument Serif', serif; }
    .mono { font-family: 'Geist Mono', monospace; }

    /* ambient gradient blobs */
    .blob {
      position: fixed;
      pointer-events: none;
      border-radius: 50%;
      filter: blur(120px);
      mix-blend-mode: screen;
      opacity: 0.45;
      z-index: 0;
    }
    .blob-1 { width: 520px; height: 520px; background: #9539FE; top: -120px; left: -120px; animation: float 22s ease-in-out infinite; }
    .blob-2 { width: 460px; height: 460px; background: #00BDE9; bottom: -120px; right: -120px; animation: float2 26s ease-in-out infinite; opacity: 0.35; }
    @keyframes float { 0%,100%{transform:translate(0,0)} 50%{transform:translate(70px,50px) scale(1.06)} }
    @keyframes float2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-60px,-40px) scale(1.04)} }

    .card {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;
      padding: 40px 36px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      backdrop-filter: blur(24px) saturate(160%);
      -webkit-backdrop-filter: blur(24px) saturate(160%);
      border-radius: 24px;
      animation: rise 1s cubic-bezier(0.16, 1, 0.3, 1) backwards;
    }
    @keyframes rise { from { opacity: 0; transform: translateY(20px); } }

    .logo {
      width: 38px; height: 38px;
      border-radius: 50%;
      background: linear-gradient(135deg, #9539FE 0%, #FF3839 50%, #00BDE9 100%);
      margin-bottom: 28px;
    }

    .eyebrow {
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }

    .input-wrap { position: relative; }
    .input {
      width: 100%;
      padding: 16px 18px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      font: inherit;
      color: white;
      font-size: 15px;
      transition: all 0.25s;
    }
    .input:focus {
      outline: none;
      background: rgba(255,255,255,0.06);
      border-color: rgba(149, 57, 254, 0.5);
      box-shadow: 0 0 0 4px rgba(149, 57, 254, 0.1);
    }
    .input::placeholder { color: rgba(255,255,255,0.3); }

    .btn {
      width: 100%;
      padding: 14px 16px;
      background: white;
      color: #08080C;
      border-radius: 12px;
      font-weight: 500;
      font-size: 14px;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .btn:hover { background: rgba(255,255,255,0.92); transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }
    .btn:disabled { opacity: 0.6; cursor: wait; }

    .error {
      margin-top: 10px;
      font-size: 13px;
      color: #FF7A7A;
      opacity: 0;
      transform: translateY(-4px);
      transition: opacity 0.3s, transform 0.3s;
    }
    .error.show { opacity: 1; transform: translateY(0); }

    .shake { animation: shake 0.4s cubic-bezier(.36,.07,.19,.97); }
    @keyframes shake {
      10%, 90% { transform: translateX(-1px); }
      20%, 80% { transform: translateX(2px); }
      30%, 50%, 70% { transform: translateX(-4px); }
      40%, 60% { transform: translateX(4px); }
    }
  </style>
</head>

<body>

  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>

  <main class="card" id="card">

    <div class="logo"></div>

    <div class="eyebrow mb-3">Dostęp</div>
    <h1 class="text-3xl font-medium tracking-tight leading-tight mb-2">
      Witaj w <span class="serif italic font-normal">Ekreacji</span>
    </h1>
    <p class="text-sm text-white/55 mb-8 leading-relaxed">
      Strona w wersji prywatnej. Podaj hasło, żeby zobaczyć galerię stylów.
    </p>

    <form id="loginForm" autocomplete="off">
      <label class="eyebrow block mb-2" for="pwd">Hasło</label>
      <div class="input-wrap">
        <input
          id="pwd"
          name="pwd"
          type="password"
          class="input"
          placeholder="••••••••"
          required
          autofocus
        />
      </div>
      <div id="err" class="error">Nieprawidłowe hasło. Spróbuj ponownie.</div>

      <button type="submit" class="btn mt-6" id="submitBtn">
        Wejdź
        <span style="font-family:'Geist Mono',monospace;">→</span>
      </button>
    </form>

    <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between text-xs text-white/35">
      <span class="mono">ekreacja · 2007–2026</span>
      <span class="mono">v1.0</span>
    </div>
  </main>

  <script is:inline define:vars={{ AUTH_HASH }}>
    const form = document.getElementById('loginForm');
    const pwdInput = document.getElementById('pwd');
    const err = document.getElementById('err');
    const btn = document.getElementById('submitBtn');
    const card = document.getElementById('card');

    // If already authed, jump to gallery
    try {
      if (localStorage.getItem('ekreacja_auth') === 'ok') {
        window.location.replace('/');
      }
    } catch (e) { /* localStorage may be blocked */ }

    async function sha256(text) {
      const buf = new TextEncoder().encode(text);
      const hash = await crypto.subtle.digest('SHA-256', buf);
      return Array.from(new Uint8Array(hash))
        .map(b => b.toString(16).padStart(2, '0'))
        .join('');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      err.classList.remove('show');
      btn.disabled = true;
      btn.textContent = 'Sprawdzam…';

      const pwd = pwdInput.value;
      const hash = await sha256(pwd);

      if (hash === AUTH_HASH) {
        try { localStorage.setItem('ekreacja_auth', 'ok'); } catch (e) {}
        btn.textContent = 'OK →';
        // small delay so user sees success feedback
        setTimeout(() => { window.location.replace('/'); }, 200);
      } else {
        err.classList.add('show');
        card.classList.remove('shake');
        // force reflow to restart animation
        void card.offsetWidth;
        card.classList.add('shake');
        btn.disabled = false;
        btn.innerHTML = 'Wejdź <span style="font-family:Geist Mono,monospace;">→</span>';
        pwdInput.value = '';
        pwdInput.focus();
      }
    });
  </script>
</body>
</html>
